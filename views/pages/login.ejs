<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>MiEcommerce | Iniciar Sesión</title>

  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css" rel="stylesheet" />
  <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" rel="stylesheet" />

  <link rel="stylesheet" href="/styles/style.css" />
</head>
<body>

  <header class="main-header">
    <div class="header-left">
      <div class="logo">
        <a href="/">MiEcommerce</a>
      </div>
    </div>
  </header>

  <main class="auth-container">
    <div class="auth-box">
      <h1>¡Hola!</h1>
      <form action="/login" method="POST" class="auth-form">
        <label>
          <span class="sr-only">Usuario</span>
          <input type="text" name="username" placeholder="Tu nombre de usuario" required />
        </label>
        <label>
          <span class="sr-only">Contraseña</span>
          <input type="password" name="password" placeholder="Tu contraseña" required />
        </label>
        <button type="submit" class="btn-auth">Iniciar Sesión</button>
      </form>
      <p class="auth-footer-text">
        ¿No tienes cuenta?
        <a href="/register">Regístrate</a>
      </p>
    </div>
  </main>

  <footer class="main-footer">
    <div class="footer-bottom">
      <div class="footer-social-left">
        <i class="fa-brands fa-instagram"></i>
        <i class="fa-brands fa-x-twitter"></i>
        <i class="fa-brands fa-facebook"></i>
        <i class="fa-brands fa-youtube"></i>
      </div>
      <p class="footer-rights">© MiEcommerce. Todos los derechos reservados.</p>
      <div class="footer-apps-right">
        <i class="fa-brands fa-google-play"></i>
        <i class="fa-brands fa-apple"></i>
      </div>
    </div>
  </footer>
</body>
</html>