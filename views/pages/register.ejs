<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
<link rel="stylesheet" href="/css/style.css" />
  <title>MiEcommerce | Regístrate</title>

  <link rel="stylesheet" href="/styles/style.css" />
</head>
<body>

  <header class="main-header">
    <div class="header-left">
      <div class="logo">
        <a href="/">MiEcommerce</a>
      </div>
    </div>
  </header>

  <main class="auth-container">
    <div class="auth-box">
      <h1>¡Regístrate!</h1>
      <form action="/register" method="POST" class="auth-form">
        <label>
          <span class="sr-only">Email</span>
          <input type="email" name="email" placeholder="Tu email" required />
        </label>
        <label>
          <span class="sr-only">Contraseña</span>
          <input type="password" name="password" placeholder="Tu nueva contraseña" required />
        </label>
        <label>
          <span class="sr-only">Repetir Contraseña</span>
          <input type="password" name="confirmPassword" placeholder="Repite tu contraseña" required />
        </label>
        <button type="submit" class="btn-auth">Crear Cuenta</button>
      </form>
      <p class="auth-footer-text">
        ¿Ya tienes cuenta?
        <a href="/login">Inicia Sesión</a>
      </p>
    </div>
  </main>

    <%- include('../partials/footer') %>
</body>
