<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>MiEcommerce | Regístrate</title>

  <!-- Tipografía Inter -->
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600&display=swap" rel="stylesheet" />
  <!-- Bootstrap Icons -->
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css" rel="stylesheet" />
  <!-- Font Awesome -->
  <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" rel="stylesheet" />
  <!-- CSS -->
  <link rel="stylesheet" href="/css/style.css" />
</head>
<body>

  <header class="main-header">
    <div class="header-left">
      <div class="logo">
        <a href="/">MiEcommerce</a>
      </div>
    </div>
  </header>

  <main class="auth-container">
    <div class="auth-box">
      <h1>¡Regístrate!</h1>

      <%# Errores server-side %>
      <% if (typeof errores !== 'undefined' && errores.length > 0) { %>
        <ul class="auth-errores">
          <% errores.forEach(function(error) { %>
            <li><%= error %></li>
          <% }) %>
        </ul>
      <% } %>

      <form id="registroForm" action="/register" method="POST" class="auth-form">

        <label>
          <span class="sr-only">Nombre</span>
          <input
            type="text"
            name="nombre"
            id="nombre"
            placeholder="Tu nombre"
            value="<%= typeof formData !== 'undefined' ? formData.nombre : '' %>"
            required
          />
        </label>

        <label>
          <span class="sr-only">Apellido</span>
          <input
            type="text"
            name="apellido"
            id="apellido"
            placeholder="Tu apellido"
            value="<%= typeof formData !== 'undefined' ? formData.apellido : '' %>"
            required
          />
        </label>

        <label>
          <span class="sr-only">Email</span>
          <input
            type="email"
            name="email"
            id="email"
            placeholder="Tu email"
            value="<%= typeof formData !== 'undefined' ? formData.email : '' %>"
            required
          />
        </label>

        <label>
          <span class="sr-only">Contraseña</span>
          <input
            type="password"
            name="password"
            id="password"
            placeholder="Tu nueva contraseña"
            required
          />
        </label>

        <button type="submit" class="btn-auth">Crear Cuenta</button>
      </form>

      <p class="auth-footer-text">
        ¿Ya tienes cuenta?
        <a href="/login">Inicia Sesión</a>
      </p>
    </div>
  </main>

  <%- include('../partials/footer') %>

  <script src="/js/register.js"></script>

</body>
</html>
