<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>MiEcommerce | Regístrate</title>

  <!-- Tipografía Inter -->
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600&display=swap" rel="stylesheet" />
  <!-- Bootstrap Icons -->
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css" rel="stylesheet" />
  <!-- Font Awesome -->
  <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" rel="stylesheet" />
  <!-- CSS -->
  <link rel="stylesheet" href="/css/style.css" />
</head>
<body>

  <header class="main-header">
    <div class="header-left">
      <div class="logo">
        <a href="/">MiEcommerce</a>
      </div>
    </div>
  </header>

  <main class="auth-container">
    <div class="auth-box">
      <h1>¡Regístrate!</h1>

      <%# Errores server-side %>
      <% if (typeof errores !== 'undefined' && errores.length > 0) { %>
        <ul class="auth-errores">
          <% errores.forEach(function(error) { %>
            <li><%= error %></li>
          <% }) %>
        </ul>
      <% } %>

      <form id="registroForm" action="/register" method="POST" class="auth-form">

        <label>
          <span class="sr-only">Nombre</span>
          <input
            type="text"
            name="nombre"
            id="nombre"
            placeholder="Tu nombre"
            value="<%= typeof formData !== 'undefined' ? formData.nombre : '' %>"
            required
          />
        </label>

        <label>
          <span class="sr-only">Apellido</span>
          <input
            type="text"
            name="apellido"
            id="apellido"
            placeholder="Tu apellido"
            value="<%= typeof formData !== 'undefined' ? formData.apellido : '' %>"
            required
          />
        </label>

        <label>
          <span class="sr-only">Email</span>
          <input
            type="email"
            name="email"
            id="email"
            placeholder="Tu email"
            value="<%= typeof formData !== 'undefined' ? formData.email : '' %>"
            required
          />
        </label>

        <label>
          <span class="sr-only">Contraseña</span>
          <input
            type="password"
            name="password"
            id="password"
            placeholder="Tu nueva contraseña"
            required
          />
        </label>

        <button type="submit" class="btn-auth">Crear Cuenta</button>
      </form>

      <p class="auth-footer-text">
        ¿Ya tienes cuenta?
        <a href="/login">Inicia Sesión</a>
      </p>
    </div>
  </main>

  <%- include('../partials/footer') %>

  <script>
    const formulario = document.getElementById('registroForm');

    formulario.addEventListener('submit', function(evento) {
      const nombre   = document.getElementById('nombre').value.trim();
      const apellido = document.getElementById('apellido').value.trim();
      const email    = document.getElementById('email').value.trim();
      const password = document.getElementById('password').value.trim();

      const errores = [];

      // Campos en blanco
      if (!nombre)   errores.push("El nombre no puede estar en blanco.");
      if (!apellido) errores.push("El apellido no puede estar en blanco.");
      if (!email)    errores.push("El email no puede estar en blanco.");
      if (!password) errores.push("La contraseña no puede estar en blanco.");

      // Formato email
      const emailRegex = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
      if (email && !emailRegex.test(email)) {
        errores.push("El formato del email no es válido.");
      }

      // Validaciones contraseña
      if (password) {
        if (password.length < 8)
          errores.push("La contraseña debe tener al menos 8 caracteres.");

        if (!/[a-zA-Z]/.test(password))
          errores.push("La contraseña debe incluir al menos una letra.");

        if (!/[0-9]/.test(password))
          errores.push("La contraseña debe incluir al menos un número.");

        if (!/[!@#$%^&*(),.?":{}|<>]/.test(password))
          errores.push("La contraseña debe incluir al menos un carácter especial (! @ # $ % etc).");

        // Cadenas prohibidas
        const passMin    = password.toLowerCase();
        const prohibidas = ["password", "1234", "qwerty", "miecommerce", nombre.toLowerCase(), apellido.toLowerCase()];

        prohibidas.forEach(function(palabra) {
          if (palabra && passMin.includes(palabra)) {
            errores.push(`La contraseña no debe contener la cadena "${palabra}".`);
          }
        });

        // No igual al email
        if (password === email) {
          errores.push("La contraseña no puede ser igual a tu email.");
        }
      }

      // Si hay errores frenamos el envío
      if (errores.length > 0) {
        evento.preventDefault();
        alert("Corregí los siguientes errores:\n\n" + errores.join("\n"));
      }
    });
  </script>

</body>
</html>
